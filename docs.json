            "icon": "trophy",
            "expanded": true,
            "root": "challenges/index",
            "pages": [
              "challenges/overview",
              "challenges/rules",
              "challenges/buying-a-challenge"
            ]
          },
          {
            "group": "Trading",
            "icon": "trending-up",
            "expanded": true,
            "root": "trading/index",
            "pages": [
              "trading/markets",
              "trading/placing-trades",
              "trading/positions-and-pnl"
            ]
          },
          {
