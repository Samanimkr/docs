{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Help Center",
  "description": "Help center and guides for PolyFundr. The first prop firm for Polymarket.",
  "colors": {
    "primary": "#0182ff",
    "light": "#ffffff",
    "dark": "#07121e"
  },
  "favicon": "https://media.brand.dev/618add50-107b-43c3-91fc-59fe7c6a2bd0.png",
  "logo": {
    "light": "/images/polyfundr-help-center-logo-light.png",
    "dark": "/images/polyfundr-help-center-logo-dark.png"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant"]
  },
  "navigation": {
    "directory": "card",
    "groups": [
      {
        "group": "Get Started",
        "icon": "rocket",
        "expanded": true,
        "root": "getting-started/index",
        "pages": [
          "getting-started/introduction",
          "getting-started/how-it-works",
          "getting-started/demo-account"
        ]
      },
      {
        "group": "Challenges",
        "icon": "trophy",
        "expanded": true,
        "root": "challenges/index",
        "pages": [
          "challenges/overview",
          "challenges/rules",
          "challenges/buying-a-challenge"
        ]
      },
      {
        "group": "Trading",
        "icon": "trending-up",
        "expanded": true,
        "root": "trading/index",
        "pages": [
          "trading/markets",
          "trading/placing-trades",
          "trading/positions-and-pnl"
        ]
      },
      {
        "group": "Funded Accounts",
        "icon": "wallet",
        "expanded": true,
        "root": "funded/index",
        "pages": [
          "funded/overview",
          "funded/payouts",
          "funded/risk-rules"
        ]
      },
      {
        "group": "Account & Wallet",
        "icon": "user",
        "expanded": true,
        "root": "account/index",
        "pages": [
          "account/signup-and-login",
          "account/wallet",
          "account/notifications"
        ]
      },
      {
        "group": "FAQ",
        "icon": "circle-question-mark",
        "expanded": true,
        "root": "faq/index",
        "pages": [
          "faq/general",
          "faq/payouts",
          "faq/rules"
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get Funded",
      "href": "https://polyfundr.com/accounts"
    }
  },
  "footer": {
    "links": [
      {
        "header": "Support",
        "items": [
          {
            "label": "Email us",
            "href": "mailto:support@polyfundr.com"
          },
          {
            "label": "Discord",
            "href": "https://discord.gg/Yby2QesUDx"
          }
        ]
      },
      {
        "header": "Socials",
        "items": [
          {
            "label": "TikTok",
            "href": "https://www.tiktok.com/@polyfundr"
          },
          {
            "label": "X (Twitter)",
            "href": "https://x.com/polyfundr"
          },
          {
            "label": "Instagram",
            "href": "https://instagram.com/polyfundr"
          },
          {
            "label": "YouTube",
            "href": "https://www.youtube.com/@PolyFundr"
          }
        ]
      }
    ]
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Montserrat",
    "weight": 500
  }
}
