{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PolyFundr",
  "description": "Documentation and guides for PolyFundr — the prop trading platform for Polymarket prediction markets.",
  "colors": {
    "primary": "#04b47c",
    "light": "#79dcbc",
